# SQLite database file path
DATABASE_URL=./db/eatom.db

# App base URL (used by better-auth for trusted origins)
NUXT_PUBLIC_APP_URL=http://localhost:3000

# better-auth secret (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=change-me-generate-a-strong-secret

# 6-digit PIN gate for demo deployment (leave empty to disable)
NUXT_PUBLIC_GATE_PIN=123456
